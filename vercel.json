{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/register.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/register",
      "destination": "/api/register.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

